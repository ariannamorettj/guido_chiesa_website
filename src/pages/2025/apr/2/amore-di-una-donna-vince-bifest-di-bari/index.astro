---
import MainLayout from '../../../../../layouts/MainLayout.astro';
---
<MainLayout title="PER AMORE DI UNA DONNA vince BIFEST di Bari | Guido Chiesa" description="2 aprile 2025 — news">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2 aprile 2025</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">PER AMORE DI UNA DONNA vince BIFEST di Bari</h1>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <p>Il film riceve il premio Bif&amp;st "Per il Cinema Italiano" come miglior film.</p>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla home</a>
    </div>
  </article>
</MainLayout>
