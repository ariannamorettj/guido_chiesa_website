---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="News | Guido Chiesa" description="Archivio news di Guido Chiesa.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">
    <div class="max-w-3xl">
      <div class="mb-4 inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-700">
        In costruzione
      </div>
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Archivio news</h1>
      <p class="mt-6 text-lg leading-8 text-zinc-500">
        Tutte le notizie e gli aggiornamenti riguardanti Guido Chiesa e i suoi progetti.
      </p>
    </div>
  </section>
</MainLayout>
