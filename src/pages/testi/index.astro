  { year: 1989, title: "Newcastle Brown Ale", href: "/testi/newcastle-brown-ale/", type: "racconto" },
  { year: 1988, title: "Il giorno in cui arrivai in America", href: "/testi/il-giorno-cui-arrivai-america/", type: "racconto" },
