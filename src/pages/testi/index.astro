  { year: 1994, title: "Verrà la morte e avrà i tuoi occhi (Lo scandalo dell'immagine della morte)", href: "/testi/verra-la-morte-e-avra-i-tuoi-occhi-lo-scandalo-del/", type: "articolo" },
  { year: 1994, title: "A che cosa serve questo giornale? Note sulla stampa musicale italiana", href: "/testi/che-cosa-serve-questo-giornale-note-sulla-stampa-m/", type: "articolo" },
  { year: 1993, title: "Il mito americano", href: "/testi/il-mito-americano-articolo/", type: "articolo" },
  { year: 1993, title: "Il buco del diavolo (Viaggio nella Valle della Morte)", href: "/testi/il-buco-del-diavolo-viaggio-nella-valle-della-mort/", type: "articolo" },
