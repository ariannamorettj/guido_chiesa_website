  { year: 2005, title: "Lavorare con saggezza", href: "/testi/lavorare-con-saggezza/", type: "articolo" },
  { year: 2005, title: "La guerra che verrà", href: "/testi/la-guerra-che-verra/", type: "articolo" },
  { year: 2004, title: "Un cinefilo pentito", href: "/testi/un-cinefilo-pentito/", type: "articolo" },
