const typeStyle: Record<TipoTesto, string> = {
  articolo:    "bg-zinc-100 text-zinc-500",
  racconto:    "bg-violet-50 text-violet-600",
  libro:       "bg-amber-50 text-amber-700",
  questionario:"bg-sky-50 text-sky-600",
};
---
<MainLayout title="Testi | Guido Chiesa" description="Racconti, articoli, interviste e scritti di Guido Chiesa.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">

    <div class="max-w-3xl">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Testi</h1>
      <blockquote class="mt-8">
        <p>In questa sezione ho incluso racconti, scritti, interviste e articoli che testimoniano momenti importanti del mio percorso. Nulla di esaustivo: brandelli di pensieri che valeva la pena mettere nero su bianco.</p>
      </blockquote>
    </div>

    <div class="mt-14 space-y-1">
      {testi.map((item) => (
        <a
          href={import.meta.env.BASE_URL + item.href.slice(1)}
          class="group flex items-baseline gap-4 rounded-xl px-4 py-3 transition hover:bg-zinc-50"
        >
          <span class="w-10 shrink-0 text-sm tabular-nums text-zinc-400">{item.year}</span>
          <span class="flex-1 text-base font-medium text-zinc-800 transition group-hover:text-emerald-700">
            {item.title}
          </span>
          <span class={`hidden shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] sm:inline-block ${typeStyle[item.type]}`}>
            {item.type}
          </span>
        </a>
      ))}
    </div>

  </section>
</MainLayout>
