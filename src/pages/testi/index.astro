  { year: 2004, title: "Venezia 2004: moto ondoso in aumento", href: "/testi/venezia-2004-moto-ondoso-aumento/", type: "articolo" },
  { year: 2003, title: "Un documentarista per caso", href: "/testi/un-documentarista-caso/", type: "articolo" },
  { year: 2003, title: "L'importante è sbagliare", href: "/testi/limportante-e-sbagliare/", type: "articolo" },
  { year: 2003, title: "Eravamo tanto punk", href: "/testi/eravamo-tanto-punk/", type: "articolo" },
