---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Eravamo tanto punk | Guido Chiesa" description="2003 — articolo">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2003 — articolo</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Eravamo tanto punk</h1>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <p>Un racconto in prima persona sul cinema indipendente americano.</p>
        
<a href="http://guidochiesa.net/media/opera/guido-chiesa/eravamo-tanto-punk/eravamo-tanto-punk.pdf" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 rounded-full bg-emerald-700 px-3.5 py-1 text-xs font-semibold text-white transition hover:bg-emerald-800">↓ eravamo-tanto-punk.pdf</a>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "testi/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna ai testi</a>
    </div>
  </article>
</MainLayout>
