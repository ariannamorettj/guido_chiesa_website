---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="The Struggle of an Italian Partisan | Guido Chiesa" description="2000 — Il partigiano Johnny">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2000 — Il partigiano Johnny</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">The Struggle of an Italian Partisan</h1>
            <p class="mt-2 text-sm text-zinc-500">Roderick Conway Morris</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href={import.meta.env.BASE_URL + "media/pressreview/il-partigiano-johnny/2000/IL PARTIGIANO JOHNNY 9_.jpg"} target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">IL PARTIGIANO JOHNNY 9_.jpg</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "rassegna-stampa/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
