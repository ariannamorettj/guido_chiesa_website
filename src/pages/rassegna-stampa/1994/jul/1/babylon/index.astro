---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Babylon | Guido Chiesa" description="1994 — Babylon">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">1994 — Babylon</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Babylon</h1>
            <p class="mt-2 text-sm text-zinc-500">P.D.</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href="http://guidochiesa.net/media/pressreview/babylon/1994/BABYLON 1.jpg" target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">BABYLON 1.jpg</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href="/rassegna-stampa/" class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
