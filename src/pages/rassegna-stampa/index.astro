          { title: "In and Out of Production", source: "Robert Aaronson, The Independent", download: "http://guidochiesa.net/media/pressreview/black-harvest/1986/BLACK%20HARVEST%201.jpg" },
          { title: "What Are Friends For?", source: "Roy Hernandez, Say! Cover New York", download: "http://guidochiesa.net/media/pressreview/black-harvest/1996/BL%20ACK%20HARVEST%202.jpg" },
        ],
      },
    ],
  },
  {
    year: "1985",
    groups: [
      {
        film: "Give Me a Spell",
        items: [
          { title: "Un film-maker e l'amore: abbandonarsi a mezzanotte", source: "La Repubblica", download: "http://guidochiesa.net/media/pressreview/give-me-spell/1986/GIVE%20ME%20A%20SPELL%202.jpg" },
          { title: "Salso Film & TV Fest", source: "Davide Ferrario, Rockerilla", download: "http://guidochiesa.net/media/pressreview/give-me-spell/1985/GIVE%20ME%20A%20SPELL%203.jpg" },
          { title: "Give Me a Spell", source: "", download: "http://guidochiesa.net/media/pressreview/give-me-spell/1985/GIVE%20ME%20A%20SPELL%201.jpg" },
        ],
      },
    ],
  },
];
---
<MainLayout title="Rassegna stampa | Guido Chiesa" description="Recensioni, interviste e articoli su Guido Chiesa.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">

    <div class="max-w-3xl mb-14">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Rassegna stampa</h1>
      <p class="mt-6 text-lg leading-8 text-zinc-600">
        Recensioni, interviste e articoli dedicati ai film e alle opere di Guido Chiesa, dalla stampa italiana e internazionale.
      </p>
    </div>

    <div class="space-y-14">
      {years.map((yearGroup) => (
        <div>
          <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">{yearGroup.year}</h2>
          <div class="space-y-8">
            {yearGroup.groups.map((filmGroup) => (
              <div>
                <h3 class="mb-2 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">{filmGroup.film}</h3>
                <ul class="space-y-0">
                  {filmGroup.items.map((item) => (
                    <li>
                      {item.download ? (
                        <details class="group">
                          <summary class="flex cursor-pointer list-none items-center gap-3 rounded-lg px-3 py-2.5 transition hover:bg-zinc-50">
                            <svg class="h-3 w-3 shrink-0 text-zinc-300 transition duration-200 group-open:rotate-90" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                            </svg>
                            <span class="flex-1 text-sm font-medium text-zinc-800">{item.title}</span>
                            {item.source && (
                              <span class="hidden shrink-0 text-xs text-zinc-400 sm:block">{item.source}</span>
                            )}
                          </summary>
                          <div class="pb-2 pl-9 pr-3 pt-1">
                            <a
                              href={item.download}
                              target="_blank"
                              rel="noopener"
                              class="inline-flex items-center gap-1.5 rounded-full bg-emerald-700 px-3.5 py-1 text-xs font-semibold text-white transition hover:bg-emerald-800"
                            >
                              ↓ Scarica
                            </a>
                          </div>
                        </details>
                      ) : (
                        <div class="flex items-center gap-3 rounded-lg px-3 py-2.5">
                          <span class="h-3 w-3 shrink-0"></span>
                          <span class="flex-1 text-sm font-medium text-zinc-500">{item.title}</span>
                          {item.source && (
                            <span class="hidden shrink-0 text-xs text-zinc-400 sm:block">{item.source}</span>
                          )}
                        </div>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </section>
</MainLayout>
