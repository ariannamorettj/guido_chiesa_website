---
<MainLayout title="Rassegna stampa | Guido Chiesa" description="Recensioni, interviste e articoli su Guido Chiesa.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">

    <div class="max-w-3xl mb-14">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Rassegna stampa</h1>
      <p class="mt-6 text-lg leading-8 text-zinc-600">
        Recensioni, interviste e articoli dedicati ai film e alle opere di Guido Chiesa, dalla stampa italiana e internazionale.
      </p>
    </div>

    <div class="space-y-14">
      {years.map((yearGroup) => (
        <div>
          <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">{yearGroup.year}</h2>
          <div class="space-y-8">
            {yearGroup.groups.map((filmGroup) => (
              <div>
                <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">{filmGroup.film}</h3>
                <ul class="space-y-0.5">
                  {filmGroup.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="group flex items-baseline gap-3 rounded-lg px-3 py-2 transition hover:bg-zinc-50"
                      >
                        <span class="flex-1 text-sm font-medium text-zinc-800 transition group-hover:text-emerald-700">
                          {item.title}
                        </span>
                        {item.source && (
                          <span class="hidden shrink-0 text-xs text-zinc-400 sm:block">{item.source}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

  </section>
</MainLayout>
