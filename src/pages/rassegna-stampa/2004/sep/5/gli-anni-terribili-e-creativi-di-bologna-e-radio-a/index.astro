---
import MainLayout from '../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Gli anni terribili e creativi di Bologna e Radio Alice | Guido Chiesa" description="2004 — Lavorare con lentezza">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2004 — Lavorare con lentezza</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Gli anni terribili e creativi di Bologna e Radio Alice</h1>
            <p class="mt-2 text-sm text-zinc-500">Roberto Nepoti</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href="http://guidochiesa.net/media/pressreview/lavorare-con-lentezza/2004/repubblica.TIF" target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">repubblica.TIF</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href="/rassegna-stampa/" class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
