---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Classe Z | Guido Chiesa" description="2017 — Classe Z">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2017 — Classe Z</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Classe Z</h1>
            <p class="mt-2 text-sm text-zinc-500">Anna Maria Pasetti</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href="http://guidochiesa.net/media/pressreview/classe-z/2017/Il Fatto quotidiano_30.032017.pdf" target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">Classe z</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "rassegna-stampa/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
