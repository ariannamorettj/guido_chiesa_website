---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Col manager rampante del suo «Caso Martello» fa centro il «deb» Chiesa, allievo di Jarmusch | Guido Chiesa" description="1991 — Il caso Martello">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">1991 — Il caso Martello</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Col manager rampante del suo «Caso Martello» fa centro il «deb» Chiesa, allievo di Jarmusch</h1>
            <p class="mt-2 text-sm text-zinc-500">Maurizio Porro</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href={import.meta.env.BASE_URL + "media/pressreview/il-caso-martello/1991/IL CASO MARTELLO  6.jpg"} target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">IL CASO MARTELLO  6.jpg</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "rassegna-stampa/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
