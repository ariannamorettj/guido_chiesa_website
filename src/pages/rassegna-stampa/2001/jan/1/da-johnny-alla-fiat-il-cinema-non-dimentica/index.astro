<MainLayout title="Da Johnny alla Fiat, il cinema non dimentica | Guido Chiesa" description="2001 — Non mi basta mai">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2001 — Non mi basta mai</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Da Johnny alla Fiat, il cinema non dimentica</h1>
            <p class="mt-2 text-sm text-zinc-500">Alberto Crespi</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href="http://guidochiesa.net/media/pressreview/non-mi-basta-mai/2001/Non mi basta mai 3.jpg" target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">Non mi basta mai 3.jpg</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href="/rassegna-stampa/" class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
