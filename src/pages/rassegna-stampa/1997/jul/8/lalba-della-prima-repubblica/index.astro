---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="L'alba della prima Repubblica | Guido Chiesa" description="1997 — Nascita di una democrazia">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">1997 — Nascita di una democrazia</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">L'alba della prima Repubblica</h1>
            <p class="mt-2 text-sm text-zinc-500">Franco Montini</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href={import.meta.env.BASE_URL + "media/pressreview/nascita-di-una-democrazia/1997/NASCITA%20DI%20UNA%20DEMOCRAZIA%201.jpg"} target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">NASCITA DI UNA DEMOCRAZIA 1.jpg</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "rassegna-stampa/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
