---
import MainLayout from '../../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Belli di papà - video recensione | Guido Chiesa" description="2015 — Belli di papà">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2015 — Belli di papà</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Belli di papà - video recensione</h1>
            <p class="mt-2 text-sm text-zinc-500">Francesco D&#39;Alò</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">

    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "rassegna-stampa/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla rassegna stampa</a>
    </div>
  </article>
</MainLayout>
