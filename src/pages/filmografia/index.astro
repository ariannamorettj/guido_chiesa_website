---
import MainLayout from '../../layouts/MainLayout.astro';
import {
  type FilmItem,
  lungometraggi as _lm,
  cortometraggi as _ct,
  serial as _sr,
  documentari as _dc,
  videoclip as _vc,
} from '../../data/filmografia';

function clean(html: string): string {
  return html
    .replace(/<p>\s*<h3>([^<]*)<\/h3>\s*(https?:\/\/[^\s<]+)\s*<\/p>/g,
      (_, label, url) => `<p><a href="${url.trim()}" target="_blank" rel="noopener">▶ ${label.trim() || 'Guarda'}</a></p>`)
    .replace(/<p>\s*<h3>[^<]*<\/h3>\s*<\/p>/g, '')
    .replace(/(<br>\s*)+$/g, '')
    .replace(/href="\.\.\/\.\.\/\.\.\/\.\.\//g, `href="${import.meta.env.BASE_URL}`)
    .replace(/href="\/(?!\/)/g, `href="${import.meta.env.BASE_URL}`)
    .replace(/<a([^>]*)>\s*Link esterno\s*<\/a>/g, (_, attrs) => {
      const hasTarget = /target=/.test(attrs);
      const hasRel = /rel=/.test(attrs);
      return `<a${attrs} class="ext-pill"${hasTarget ? '' : ' target="_blank"'}${hasRel ? '' : ' rel="noopener"'}>↗ Link esterno</a>`;
    })
    .trim();
}

const lungometraggi = _lm.map(f => ({ ...f, content: f.content ? clean(f.content) : null }));
const cortometraggi = _ct.map(f => ({ ...f, content: f.content ? clean(f.content) : null }));
const serial = _sr.map(f => ({ ...f, content: f.content ? clean(f.content) : null }));
const documentari = _dc.map(f => ({ ...f, content: f.content ? clean(f.content) : null }));
const videoclip = _vc.map(f => ({ ...f, content: f.content ? clean(f.content) : null }));

const sections = [
  { label: "Lungometraggi", items: lungometraggi },
  { label: "Documentari", items: documentari },
  { label: "Serial", items: serial },
  { label: "Cortometraggi", items: cortometraggi },
  { label: "Videoclip", items: videoclip },
];

const total = sections.reduce((n, s) => n + s.items.length, 0);
const withContent = sections.reduce((n, s) => n + s.items.filter(i => i.content).length, 0);
---

<MainLayout title="Filmografia | Guido Chiesa" description="Filmografia completa di Guido Chiesa: lungometraggi, documentari, cortometraggi, serial e videoclip.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">

    <div class="max-w-3xl">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Filmografia</h1>
      <blockquote class="mt-8">
        <p>Un elenco non significa molto in sé e per sé. Talvolta gli spazi tra un titolo e l'altro nascondono più di quanto i lavori realizzati riescano a spiegare. Se non altro il desiderio di proseguire oltre che si accompagna ad ogni parola "fine".</p>
      </blockquote>
    </div>

    <div class="mt-16 grid gap-12 lg:grid-cols-[1fr_280px]">

      <div class="space-y-14">
        {sections.map(({ label, items }) => (
          <div>
            <div class="mb-4 flex items-center gap-4">
              <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-400">{label}</h2>
              <div class="h-px flex-1 bg-zinc-100"></div>
            </div>

            <div class="space-y-0.5">
              {items.map((item) => {
                const slug = item.href ? item.href.replace('/filmografia/', '').replace(/\/$/, '') : null;
                return item.content ? (
                  <details id={slug ?? undefined} class="group rounded-2xl border border-transparent transition hover:border-black/5 hover:bg-white hover:shadow-[0_4px_20px_-8px_rgba(0,0,0,0.10)]">
                    <summary class="flex cursor-pointer list-none items-baseline gap-5 px-4 py-2.5">
                      <span class="w-10 shrink-0 text-sm tabular-nums text-zinc-400">{item.year}</span>
                      <span class="flex flex-1 items-center justify-between gap-4">
                        <span class="text-base font-medium text-zinc-800">{item.title}</span>
                        <svg class="h-4 w-4 shrink-0 text-zinc-300 transition duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.51a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd" />
                        </svg>
                      </span>
                    </summary>
                    <div class="film-content pb-5 pl-[3.75rem] pr-4 text-sm leading-7 text-zinc-600">
                      <Fragment set:html={item.content} />
                    </div>
                  </details>
                ) : (
                  <div class="flex items-baseline gap-5 px-4 py-2.5">
                    <span class="w-10 shrink-0 text-sm tabular-nums text-zinc-400">{item.year}</span>
                    {slug ? (
                      <a href={'#' + slug} class="text-base font-medium text-zinc-800 transition hover:text-emerald-700">
                        {item.title}
                      </a>
                    ) : (
                      <span class="text-base font-medium text-zinc-500">{item.title}</span>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>

      <aside class="lg:pt-1">
        <div class="sticky top-24 space-y-4">
          <div id="stats-card" class="rounded-3xl border border-black/5 bg-white p-6 shadow-[0_12px_40px_-24px_rgba(0,0,0,0.12)]">
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">In cifre</div>
            <ul class="mt-5 space-y-3">
              {sections.map(({ label, items }) => (
                <li class="flex items-center justify-between gap-4">
                  <span class="text-sm text-zinc-600">{label}</span>
                  <span class="text-sm font-semibold tabular-nums text-zinc-900" data-counter>{items.length}</span>
                </li>
              ))}
              <li class="flex items-center justify-between gap-4 border-t border-zinc-100 pt-4">
                <span class="text-sm font-semibold text-zinc-900">Totale</span>
                <span class="text-sm font-semibold tabular-nums text-emerald-700" data-counter>{total}</span>
              </li>
              <li class="flex items-center justify-between gap-4 border-t border-zinc-100 pt-3">
                <span class="text-sm text-zinc-500">Con note d'autore</span>
                <span class="text-sm font-semibold tabular-nums text-zinc-500" data-counter>{withContent}</span>
              </li>
            </ul>
          </div>

          <div class="flex flex-col gap-3">
            {[
              { label: "Sceneggiature", href: import.meta.env.BASE_URL + "sceneggiature/" },
              { label: "Rassegna stampa", href: import.meta.env.BASE_URL + "rassegna-stampa/" },
              { label: "Biografia", href: import.meta.env.BASE_URL + "biografia/" },
            ].map(({ label, href }) => (
              <a href={href} class="group flex items-center justify-between rounded-2xl border border-black/5 bg-white px-5 py-3.5 text-sm font-medium text-zinc-700 transition hover:-translate-y-0.5 hover:shadow-[0_8px_24px_-12px_rgba(0,0,0,0.16)]">
                {label}
                <span class="text-zinc-400 transition group-hover:translate-x-0.5 group-hover:text-emerald-700">→</span>
              </a>
            ))}
          </div>
        </div>
      </aside>

    </div>
  </section>
</MainLayout>

<style>
  .film-content p { margin-bottom: 0.75rem; }
  .film-content p:last-child { margin-bottom: 0; }
  .film-content a { color: #059669; text-decoration: underline; text-underline-offset: 3px; }
  .film-content a:hover { color: #047857; }
  .film-content a.ext-pill {
    display: inline-flex; align-items: center; gap: 4px;
    border-radius: 9999px; border: 1px solid #a7f3d0; background: #f0fdf4;
    padding: 3px 12px; font-size: 0.75rem; font-weight: 600;
    color: #059669; text-decoration: none;
  }
  .film-content a.ext-pill:hover { background: #d1fae5; color: #047857; }
  .film-content em { font-style: italic; }
  .film-content strong { font-weight: 600; color: #18181b; }
</style>

<script>
  function slotCounter(el: HTMLElement) {
    const target = parseInt(el.textContent?.trim() ?? '0', 10);
    if (isNaN(target)) return;

    const isDouble = target >= 10;
    let ticks = 0;
    const maxTicks = 9;

    const spin = setInterval(() => {
      ticks++;
      el.textContent = isDouble
        ? String(Math.floor(Math.random() * 90 + 10))
        : String(Math.floor(Math.random() * 10));

      if (ticks >= maxTicks) {
        clearInterval(spin);
        const duration = 380;
        const t0 = performance.now();
        function countUp(now: number) {
          const p = Math.min((now - t0) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 2);
          el.textContent = String(Math.round(eased * target));
          if (p < 1) requestAnimationFrame(countUp);
          else el.textContent = String(target);
        }
        requestAnimationFrame(countUp);
      }
    }, 55);
  }

  const statsCard = document.getElementById('stats-card');
  if (statsCard) {
    let triggered = false;

    function runSlot() {
      if (triggered) return;
      triggered = true;
      const counters = statsCard.querySelectorAll<HTMLElement>('[data-counter]');
      counters.forEach((el, i) => setTimeout(() => slotCounter(el), i * 110));
    }

    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        obs.disconnect();
        runSlot();
      }
    }, { threshold: 0.5, rootMargin: '-40px 0px -40px 0px' });

    // Avvia l'observer solo dopo il primo scroll, non al caricamento
    window.addEventListener('scroll', function onFirstScroll() {
      window.removeEventListener('scroll', onFirstScroll);
      obs.observe(statsCard);
    }, { passive: true });
  }

  // Auto-open <details> targeted by URL hash (e.g. /filmografia/#il-caso-martello)
  function openFromHash() {
    const id = window.location.hash.slice(1);
    if (!id) return;
    const el = document.getElementById(id);
    if (el && el.tagName === 'DETAILS') {
      (el as HTMLDetailsElement).open = true;
      el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }
  openFromHash();
  window.addEventListener('hashchange', openFromHash);
</script>
