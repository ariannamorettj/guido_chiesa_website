---
import MainLayout from '../../layouts/MainLayout.astro';

interface ProgettoItem {
  year: number;
  title: string;
  href: string;
}

const progetti: ProgettoItem[] = [
  { year: 1999, title: "We Are The Champions", href: "/progetti/we-are-champions/" },
  { year: 2003, title: "Lacrime e sorrisi", href: "/progetti/lacrime-e-sorrisi/" },
  { year: 2004, title: "Piazza grande", href: "/progetti/piazza-grande/" },
  { year: 2005, title: "Home", href: "/progetti/home/" },
  { year: 2006, title: "Una città che non c'è più", href: "/progetti/una-citta-che-non-ce-piu/" },
  { year: 2008, title: "Caulonia 1945 — I 5 giorni che non cambiarono nulla", href: "/progetti/caulonia/" },
];
---
<MainLayout title="Progetti | Guido Chiesa" description="Idee di documentari mai realizzati di Guido Chiesa.">
  <section class="mx-auto max-w-7xl px-6 py-16 lg:py-24">

    <div class="max-w-3xl">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Progetti</h1>
      <blockquote class="mt-8">
        <p>I progetti nascono e muoiono come le storie e i ricordi.<br />
        Ma qualcuno mi piace sottrarlo all'oblio.<br />
        Qui raccolte alcune idee di documentari mai realizzati, ma sempre disponibili all'uso.</p>
      </blockquote>
    </div>

    <div class="mt-14 space-y-1">
      {progetti.map((item) => (
        <a
          href={import.meta.env.BASE_URL + item.href.slice(1)}
          class="group flex items-baseline gap-4 rounded-xl px-4 py-3 transition hover:bg-zinc-50"
        >
          <span class="w-10 shrink-0 text-sm tabular-nums text-zinc-400">{item.year}</span>
          <span class="flex-1 text-base font-medium text-zinc-800 transition group-hover:text-emerald-700">
            {item.title}
          </span>
          <span class="hidden shrink-0 rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] bg-teal-50 text-teal-600 sm:inline-block">
            progetto
          </span>
        </a>
      ))}
    </div>

  </section>
</MainLayout>
