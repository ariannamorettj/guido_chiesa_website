---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Home | Guido Chiesa" description="2005 — progetto">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2005 — progetto</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Home</h1>
      <p class="mt-2 text-sm text-zinc-500">scritto da Guido Chiesa, Nicoletta Micheli</p>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <p>Progetto per un documentario.</p>
      <h2>Download</h2>
      <ul class="space-y-1">
        <li><a href="http://guidochiesa.net/media/opera/guido-chiesa-nicoletta-micheli/home/Home.pdf" target="_blank" class="text-emerald-700 hover:text-emerald-800 transition">Home.pdf</a></li>
      </ul>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href="/progetti/" class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna ai progetti</a>
    </div>
  </article>
</MainLayout>
