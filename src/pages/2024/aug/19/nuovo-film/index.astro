---
import MainLayout from '../../../../../layouts/MainLayout.astro';
---
<MainLayout title="Nuovo film | Guido Chiesa" description="19 agosto 2024 — news">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">19 agosto 2024</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Nuovo film</h1>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <p>Prime informazioni sul dodicesimo film di finzione, ancora senza titolo e data di uscita.</p>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla home</a>
    </div>
  </article>
</MainLayout>
