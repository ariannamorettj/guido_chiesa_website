---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Manuale di regia cinematografica | Bibliografia | Guido Chiesa" description="Scheda del libro Manuale di regia cinematografica, UTET 2011">
  <article class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <div class="mb-8">
      <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">2011 — libro</div>
      <h1 class="mt-3 text-4xl font-semibold tracking-[-0.06em] text-zinc-900 sm:text-5xl">Manuale di regia cinematografica</h1>
    </div>
    <div class="prose-guido space-y-5 text-base leading-8 text-zinc-700">
      <p><strong>Guido Chiesa</strong>, <em>Manuale di regia cinematografica</em>, UTET, Torino, ottobre 2011.</p>
      <p>Vincitore del Premio Diego Fabbri. Il volume raccoglie e sistematizza gli strumenti fondamentali del mestiere del regista cinematografico, dall'ideazione alla post-produzione.</p>
      <p class="text-sm text-zinc-500">
        L'introduzione è disponibile nella sezione <a href={import.meta.env.BASE_URL + "testi/manuale-di-regia-cinematografica/"} class="text-emerald-700 hover:text-emerald-800 transition">Testi</a>.
      </p>
    </div>
    <div class="mt-16 border-t border-zinc-100 pt-8">
      <a href={import.meta.env.BASE_URL + "bibliografia/"} class="text-sm font-semibold text-emerald-700 transition hover:text-emerald-800">&larr; Torna alla bibliografia</a>
    </div>
  </article>
</MainLayout>
