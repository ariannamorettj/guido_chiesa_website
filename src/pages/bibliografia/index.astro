---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Bibliografia | Guido Chiesa" description="Pubblicazioni di e su Guido Chiesa.">
  <section class="mx-auto max-w-3xl px-6 py-16 lg:py-24">

    <div class="mb-12">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Bibliografia</h1>
      <blockquote class="mt-8">
        <p>Qui sono inclusi i libri e i saggi brevi da me pubblicati, nonché i libri, le tesi di laurea e i saggi brevi realizzati sul mio lavoro.</p>
      </blockquote>
    </div>

    <div class="space-y-14">

      <!-- PUBBLICAZIONI -->
      <div>
        <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">Pubblicazioni</h2>

        <div class="space-y-10">

          <!-- Saggi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2011</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <a href={import.meta.env.BASE_URL + "testi/manuale-di-regia-cinematografica/"} class="font-medium text-zinc-900 hover:text-emerald-700 transition"><em>Manuale di regia cinematografica</em></a>, UTET, Torino.
                  <a href={import.meta.env.BASE_URL + "bibliografia/manuale-di-regia-cinematografica/"} class="link-pill">scheda</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2009</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Dove c'è sentimento c'è speranza</em>, in A. Aprà (a cura di), <em>Fuori norma. La via italiana al documentario</em>, Marsilio, Venezia.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2007</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Beppe Fenoglio: un uomo verticale</em>, in M. Quaglia (a cura di), <em>Omaggio a Beppe Fenoglio</em>, Regione Piemonte, Torino.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2005</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Lavorare con saggezza</em>, in P. Pezzino (a cura di), <em>Laboratorio di storia. Storiografia, didattica, multimedialità</em>, Pacini Editore, Pisa.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2003</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Un documentarista per caso</em>, in AA.VV., <em>Fare documentario oggi in Italia</em>, Marsilio, Venezia.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2001</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Historia magistra vitae?</em>, in C. Uva (a cura di), <em>Storie d'Italia</em>, Bietti, Milano.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1982</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Blondie</em>, in AA.VV., <em>New Wave</em>, Arcana, Roma.
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi brevi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi brevi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2006</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Lo sguardo dello spettatore</em>, in M. De Rosa e A. Mirizio (a cura di), <em>Kinema. Una visione del cinema nell'epoca di internet</em>, Costa&amp;Nolan, Genova.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1998</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Note a margine del re-mix di PJ Harvey</em>, in AA.VV., <em>Is This Desire? di PJ Harvey</em>, Arcana, Roma.
                  <a href="http://guidochiesa.net/media/opera/note-a-pj/note-a-pj.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1995</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Presentazione</em>, in M. Pavesi, <em>Fictions of the Screen</em>, Unicopli, Milano.
                </span>
              </li>
            </ul>
          </div>

        </div>
      </div>

      <!-- HANNO SCRITTO SUL MIO LAVORO -->
      <div>
        <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">Hanno scritto sul mio lavoro</h2>

        <div class="space-y-10">

          <!-- Monografie -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Monografie</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2001</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. Carluccio e F. Villa (a cura di), <em>Il cinema di Guido Chiesa</em>, Lindau, Torino.
                  <a href="https://www.ibs.it/cinema-di-guido-chiesa-libro-vari/e/9788871802060" target="_blank" rel="noopener" class="link-pill">ibs.it ↗</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2001</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. Carluccio (a cura di), <em>Il partigiano Johnny. Dal romanzo al film</em>, Lindau, Torino.
                  <a href="https://www.ibs.it/partigiano-johnny-dal-romanzo-al-libro-vari/e/9788871802534" target="_blank" rel="noopener" class="link-pill">ibs.it ↗</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2000</span>
                <span class="text-sm leading-6 text-zinc-700">
                  C. Bragaglia, <em>Il piacere del racconto. Narrativa italiana e cinema (1895–2000)</em>, La Nuova Italia, Firenze.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1999</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Della Casa (a cura di), <em>Storie di cinema piemontese</em>, Regione Piemonte, Torino.
                </span>
              </li>
            </ul>
          </div>

          <!-- Tesi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Tesi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2007</span>
                <span class="text-sm leading-6 text-zinc-700">
                  F. Billi, <em>Il cinema di Guido Chiesa tra narrativa e musica</em>, Università degli Studi di Firenze, rel. G. Carluccio.
                  <a href="http://guidochiesa.net/media/opera/tesi-billi/tesi-billi.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2006</span>
                <span class="text-sm leading-6 text-zinc-700">
                  C. Deidier, <em>Analisi del film "Lavorare con lentezza"</em>, Università degli Studi di Torino, rel. G. Carluccio.
                  <a href="http://guidochiesa.net/media/opera/tesi-deidier/tesi-deidier.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2005</span>
                <span class="text-sm leading-6 text-zinc-700">
                  C. Sinicco, <em>Il partigiano Johnny: dal romanzo di Fenoglio al film di Chiesa</em>, Università degli Studi di Torino, rel. G. Carluccio.
                  <a href="http://guidochiesa.net/media/opera/tesi-sinicco/tesi-sinicco.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2004</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Gili, <em>Io no: un film sull'obiezione di coscienza</em>, Università degli Studi di Torino, rel. G. Carluccio.
                  <a href="http://guidochiesa.net/media/opera/tesi-gili/tesi-gili.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2004</span>
                <span class="text-sm leading-6 text-zinc-700">
                  F. Cattaneo, <em>Il cinema di Guido Chiesa</em>, Università Cattolica del Sacro Cuore di Milano, rel. A. Costa.
                  <a href="http://guidochiesa.net/media/opera/tesi-cattaneo/tesi-cattaneo.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2003</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Arecco, <em>Il partigiano Johnny: studio sul film</em>, Università degli Studi di Genova, rel. S. Della Casa.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2002</span>
                <span class="text-sm leading-6 text-zinc-700">
                  A. Ferretti, <em>Lavorare con lentezza: un film su Radio Alice</em>, Università degli Studi di Bologna, rel. L. Quaresima.
                  <a href="http://guidochiesa.net/media/opera/tesi-ferretti/tesi-ferretti.pdf" target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi brevi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi brevi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2005</span>
                <span class="text-sm leading-6 text-zinc-700">
                  R. De Berti e I. Moscati (a cura di), <em>Schermi di regime. Cinema italiano degli anni Trenta: la produzione e i generi</em>, Bietti, Milano.
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi generali -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi generali</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2008</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. De Vincenti (a cura di), <em>Storia del cinema italiano, vol. XI (1980–1989)</em>, Marsilio/Bianco e Nero, Venezia-Roma.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2003</span>
                <span class="text-sm leading-6 text-zinc-700">
                  A. Manzoli e G. Pescatore (a cura di), <em>L'arte del risparmio. Stile e tecnologia</em>, Carocci, Roma.
                  <a href="https://www.ibs.it/arte-del-risparmio-stile-tecnologia-libro-vari/e/9788843025503" target="_blank" rel="noopener" class="link-pill">ibs.it ↗</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1999</span>
                <span class="text-sm leading-6 text-zinc-700">
                  A. Morini (a cura di), <em>Il cinema dei giovani registi italiani</em>, Lindau, Torino.
                </span>
              </li>
            </ul>
          </div>

        </div>
      </div>

    </div>
  </section>
</MainLayout>
