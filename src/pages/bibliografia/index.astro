---
import MainLayout from '../../layouts/MainLayout.astro';
---
<MainLayout title="Bibliografia | Guido Chiesa" description="Pubblicazioni di e su Guido Chiesa.">
  <section class="mx-auto max-w-3xl px-6 py-16 lg:py-24">

    <div class="mb-12">
      <h1 class="text-5xl font-semibold tracking-[-0.07em] text-zinc-900 sm:text-6xl">Bibliografia</h1>
      <blockquote class="mt-8 space-y-3 text-sm leading-7 text-zinc-600">
        <p>Qui sono inclusi i libri e i saggi brevi da me pubblicati, nonché i libri, le tesi di laurea e i saggi brevi realizzati sul mio lavoro.</p>
        <p>Per anni, scrivere è stata la principale fonte di reddito, tra musica e giornalismo. La scrittura non mi somiglia, troppo sedentario e solitario per quanto individualista possa essere. Però mi seduce e coinvolge, come poco altro.</p>
      </blockquote>
    </div>

    <div class="space-y-14">

      <!-- PUBBLICAZIONI -->
      <div>
        <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">Pubblicazioni</h2>

        <div class="space-y-10">

          <!-- Saggi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2011</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <a href={import.meta.env.BASE_URL + "testi/manuale-di-regia-cinematografica/"} class="font-medium text-zinc-900 hover:text-emerald-700 transition"><em>Manuale di regia cinematografica</em></a>, Torino, UTET.
                  <a href={import.meta.env.BASE_URL + "bibliografia/manuale-di-regia-cinematografica/"} class="link-pill">scheda</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1993</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>The Sound of Seattle</em>, con Steve Blush, Viterbo, Nuovi Equilibri.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1992</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Sonic Youth / Sonic Life</em>, Viterbo, Nuovi Equilibri.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1992</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Hip hop Rap: potere alla parola = word power</em>, Viterbo, Nuovi Equilibri.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1986</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Rockin' USA. La musica americana dal punk ai giorni nostri</em>, con Alberto Campo, Milano, Arcana.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1985</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>La New Wave. L'ultimo cinema newyorkese</em>, Torino, Aiace.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1982</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>I generi cinematografici: teoria, produzione, storia</em>, Torino, CIDEC.
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi brevi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi brevi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2006</span>
                <span class="text-sm leading-6 text-zinc-700">
                  <em>Lo sguardo epico del partigiano Johnny</em>, in <em>Esperienze letterarie</em>.
                  <a href={import.meta.env.BASE_URL + "media/opera/guido-chiesa/sguardo-epico-partigiano-johnny/note-a-pj.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2003</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. Spagnoletti - R. Pisoni, <em>John Sayles e il cinema indipendente USA</em>, Lindau, Torino.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1995</span>
                <span class="text-sm leading-6 text-zinc-700">
                  AA.VV., <em>Materiali resistenti</em>, Dinosaura/Laboratorio 80.
                </span>
              </li>
            </ul>
          </div>

        </div>
      </div>

      <!-- HANNO SCRITTO SUL MIO LAVORO -->
      <div>
        <h2 class="mb-6 text-2xl font-semibold tracking-[-0.04em] text-zinc-900">Hanno scritto sul mio lavoro</h2>

        <div class="space-y-10">

          <!-- Monografie -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Monografie</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2001</span>
                <span class="text-sm leading-6 text-zinc-700">
                  Cinecritica, <em>Il cinema di Guido Chiesa</em>, SNCCI.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2000</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. De Luna, T. Masoni, P. Vecchi, <em>Guido Chiesa. Un regista, la memoria, la storia</em>, Comune di Correggio.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2000</span>
                <span class="text-sm leading-6 text-zinc-700">
                  D. De Gaetano, <em>Tra emozione e ragione. Il cinema di Guido Chiesa</em>, Lindau, Torino.
                  <a href="http://www.ibs.it/code/9788871803425/tra-emozione-ragione.html" target="_blank" rel="noopener" class="link-pill">ibs.it ↗</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1999</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Della Casa, S. Martina, <em>Il caso Chiesa</em>, catalogo di Arcipelago, Roma.
                </span>
              </li>
            </ul>
          </div>

          <!-- Tesi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Tesi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2007</span>
                <span class="text-sm leading-6 text-zinc-700">
                  B. Groppo, <em>Musica e storia a confronto nel cinema di Guido Chiesa</em>, Torino.
                  <a href={import.meta.env.BASE_URL + "media/opera/groppo-benedetta-musica-e-storia-confronto-nel-cin/tesi%20Benedetta%20Groppo.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2007</span>
                <span class="text-sm leading-6 text-zinc-700">
                  A. Voltaggio, <em>Spazi partigiani: il paesaggio nella narrativa della Resistenza italiana</em>, Bologna.
                  <a href={import.meta.env.BASE_URL + "media/opera/voltaggio-anna-spazi-partigiani-il-paesaggio-nella/tesi%20Anna%20Voltaggio.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2007</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Brambilla, <em>Possibilities of Italian Ostalgie</em>, University of Sussex, Brighton.
                  <a href={import.meta.env.BASE_URL + "media/opera/brambilla-stefania-possibilities-italian-ostalgie-/tesi%20Stefania%20Brambilla.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2006</span>
                <span class="text-sm leading-6 text-zinc-700">
                  C. Cozzi, <em>Accoglienza critica italiana di Lavorare con lentezza</em>, Milano.
                  <a href={import.meta.env.BASE_URL + "media/opera/cozzi-claudia-accoglienza-critica-italiana-di-lavo/TESI%20COZZI.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2005</span>
                <span class="text-sm leading-6 text-zinc-700">
                  A. Sforzi, <em>A bottega. Pratica produttiva ed esperienza formativa sul set di Lavorare con lentezza</em>.
                  <a href={import.meta.env.BASE_URL + "media/opera/sforzi-adriano-bottega-pratica-produttiva-ed-esper/adriano%20sforzi.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2003</span>
                <span class="text-sm leading-6 text-zinc-700">
                  G. Dilonardo, <em>Lavorare con lentezza di Guido Chiesa. Genesi di un film</em>, Bologna.
                  <a href={import.meta.env.BASE_URL + "media/opera/dilonardo-giuseppe-lavorare-con-lentezza-di-guido-/Tesi%20Giuseppe%20Dilonardo.pdf"} target="_blank" rel="noopener" class="link-pill">PDF ↓</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2002</span>
                <span class="text-sm leading-6 text-zinc-700">
                  D. Raganati, <em>Guido Chiesa: un percorso indipendente. Il metodo, i progetti, le idee</em>, Bologna.
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi brevi -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi brevi</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2005</span>
                <span class="text-sm leading-6 text-zinc-700">
                  C. Clò, <em>Spaesamenti padani</em>.
                </span>
              </li>
            </ul>
          </div>

          <!-- Saggi generali -->
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-[0.16em] text-zinc-400">Saggi generali</h3>
            <ul class="space-y-4">
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2008</span>
                <span class="text-sm leading-6 text-zinc-700">
                  D. De Gaetano, <em>Torino Ciak si Gira. Breve storia del cinema a Torino</em>, Lindau.
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">2004</span>
                <span class="text-sm leading-6 text-zinc-700">
                  M. Fantoni Minnella, <em>Non riconciliati. Politica e società nel cinema italiano dal neorealismo a oggi</em>.
                  <a href="http://www.ibs.it/code/9788877509185/fantoni-minnella-maurizi/non-riconciliati-politica.html" target="_blank" rel="noopener" class="link-pill">ibs.it ↗</a>
                </span>
              </li>
              <li class="flex gap-4">
                <span class="w-10 shrink-0 tabular-nums text-sm text-zinc-400">1999</span>
                <span class="text-sm leading-6 text-zinc-700">
                  S. Arcagni, D. De Gaetano, <em>Cinema e rock. Cinquant'anni di contaminazioni tra musica e immagini</em>.
                </span>
              </li>
            </ul>
          </div>

        </div>
      </div>

    </div>
  </section>
</MainLayout>
