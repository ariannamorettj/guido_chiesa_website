---
import { footerLinks } from "../data/navigation";
---

<footer class="mt-24 border-t border-black/5 bg-white">
  <div class="mx-auto max-w-7xl px-6 py-10">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-md">
        <a href={import.meta.env.BASE_URL} class="text-xl font-semibold uppercase tracking-[-0.08em] text-zinc-800 transition hover:text-emerald-700">
          Guido Chiesa
        </a>
        <p class="mt-3 text-sm leading-6 text-zinc-500">
          Archivio di opere, scritti, materiali visivi e aggiornamenti.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-8 gap-y-3 text-sm text-zinc-600 sm:grid-cols-3 lg:grid-cols-4">
        {footerLinks.map((item) => (
          <a href={item.href} class="transition hover:text-emerald-700 hover:underline underline-offset-4 decoration-1">{item.label}</a>
        ))}
      </div>
    </div>

    <div class="mt-8 flex items-center justify-between border-t border-zinc-200 pt-6 text-xs text-zinc-500">
      <span>© {new Date().getFullYear()} Guido Chiesa</span>
      <a href={import.meta.env.BASE_URL + "copyright/"} class="transition hover:text-zinc-700">Copyright</a>
    </div>
  </div>
</footer>
