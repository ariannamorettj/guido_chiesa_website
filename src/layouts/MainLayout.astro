---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Guido Chiesa: regista e sceneggiatore" } = Astro.props;
---

<!doctype html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={import.meta.env.BASE_URL + "favicon_round.png"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,600;0,700;1,600;1,700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-stone-50 text-zinc-900 antialiased">
    <!-- Full-page holographic background -->
    <div id="holo-bg"></div>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>

<style is:global>
  /* ── Full-page holographic background (all pages) ── */
  #holo-bg {
    position: fixed;
    inset: 0;
    z-index: -10;
    background:
      radial-gradient(ellipse 75% 55% at 12% 20%, hsla(280, 70%, 72%, 0.18) 0%, transparent 65%),
      radial-gradient(ellipse 60% 50% at 88% 72%, hsla(155, 70%, 62%, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 70% 45% at 55% 2%,  hsla(35,  80%, 76%, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse 55% 45% at 78% 18%, hsla(210, 70%, 68%, 0.11) 0%, transparent 52%),
      radial-gradient(ellipse 50% 40% at 20% 85%, hsla(320, 65%, 68%, 0.10) 0%, transparent 52%);
    filter: hue-rotate(var(--holo-hue, 0deg));
    transition: filter 0.15s ease-out;
  }

  /* ── Page-enter animation ── */
  @keyframes page-enter {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  main {
    animation: page-enter 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── Scroll-reveal (all pages) ── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // ── Holographic engine — all pages ──
  let baseHue = 0;
  let scrollHue = 0;
  let rafId: number;
  const SPEED = 0.18; // medium drift (~35s per full cycle)

  function applyHue() {
    const combined = (baseHue + scrollHue) % 360;
    document.documentElement.style.setProperty('--holo-hue', `${combined}deg`);
  }

  function tick() {
    baseHue = (baseHue + SPEED) % 360;
    applyHue();
    rafId = requestAnimationFrame(tick);
  }
  rafId = requestAnimationFrame(tick);

  // Scroll adds a position-based hue offset (scrollytelling)
  window.addEventListener('scroll', () => {
    const maxScroll = Math.max(1, document.documentElement.scrollHeight - innerHeight);
    const progress = window.scrollY / maxScroll;
    // 0→180° extra hue shift from top to bottom of page
    scrollHue = progress * 180;
    applyHue();
  }, { passive: true });

  // ── Scroll-reveal — all pages ──
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        setTimeout(() => el.classList.add('is-visible'), Number(el.dataset.delay ?? 0));
        observer.unobserve(el);
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el) => observer.observe(el));
</script>
